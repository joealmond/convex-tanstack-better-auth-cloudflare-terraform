{
  "name": "convexkit",
  "version": "2.0.0",
  "description": "Edge-ready starter kit for TanStack Start, Convex, Better Auth, and Cloudflare Workers",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "dev": "concurrently -r \"npm:dev:web\" \"npm:dev:convex\"",
    "dev:web": "vite dev",
    "dev:convex": "npx convex dev",
    "build": "vite build",
    "build:preview": "cross-env CLOUDFLARE_ENV=preview vite build --mode preview",
    "build:prod": "cross-env CLOUDFLARE_ENV=production vite build --mode production",
    "preview": "wrangler dev",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:public": "playwright test e2e/public-smoke.spec.ts",
    "test:e2e:auth": "playwright test e2e/authenticated-flow.spec.ts",
    "test:cli": "node --test packages/create-convexkit/test/scaffold.node-test.mjs",
    "test:watch": "vitest",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "check": "npm run format:check && npm run lint -- --max-warnings=0 && npm run test:coverage && npm run test:cli && npm run typecheck && npm audit --audit-level=low && npm run build && npm run docs:build",
    "generate:routes": "node -e \"const{getConfig:g,Generator:G}=require('@tanstack/router-generator');new G({config:g({},process.cwd()),root:process.cwd()}).run()\"",
    "sync:wrangler-config": "node scripts/generate-wrangler-config.mjs",
    "convex:push": "npx convex dev --once",
    "convex:deploy": "npx convex deploy --yes",
    "deploy:preview": "npm run convex:push && npm run build:preview && npm run sync:wrangler-config && wrangler deploy --config dist/server/wrangler.json",
    "deploy:prod": "npm run convex:deploy && npm run build:prod && npm run sync:wrangler-config && wrangler deploy --config dist/server/wrangler.json",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.44.0",
    "@convex-dev/better-auth": "^0.12.5",
    "@convex-dev/rate-limiter": "^0.3.2",
    "@convex-dev/react-query": "^0.1.0",
    "@hookform/resolvers": "^5.0.1",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-router": "^1.168.27",
    "@tanstack/react-router-ssr-query": "^1.167.1",
    "@tanstack/react-start": "^1.168.27",
    "@tanstack/react-table": "^8.21.3",
    "better-auth": "~1.6.15",
    "convex": "^1.42.1",
    "convex-helpers": "^0.1.112",
    "lucide-react": "^0.563.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-hook-form": "^7.57.0",
    "resend": "^6.17.2",
    "sonner": "^2.0.7",
    "stripe": "^22.3.1",
    "zod": "^4.3.5"
  },
  "optionalDependencies": {
    "@sentry/react": "^9.36.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/dom": "^10.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^24.10.9",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^3.2.7",
    "autoprefixer": "^10.4.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "convex-test": "^0.0.54",
    "cross-env": "^10.1.0",
    "eslint": "^9.0.0",
    "happy-dom": "^20.3.7",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.18",
    "terser": "^5.44.1",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^6.0.5",
    "vitepress": "^2.0.0-alpha.18",
    "vitest": "^3.2.4",
    "wrangler": "^4.107.0"
  }
}
