# Copy to terraform.tfvars. Never commit the populated file.
cloudflare_api_token  = ""
cloudflare_account_id = ""
resource_prefix       = "convexkit-production"

# These resources are optional and are not bound to the app automatically.
enable_kv_cache   = false
enable_r2_storage = false
r2_location       = "weur"

enable_turnstile  = false
turnstile_domains = ["localhost"]

enable_analytics  = false
cloudflare_zone_id = ""
